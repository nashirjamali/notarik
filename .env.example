OPENROUTER_API_KEY=your_openrouter_api_key
# Must support image input (vision). Text-only models will fail on receipt scans.
OPENROUTER_MODEL=google/gemini-2.5-flash

# Supabase Auth (Google) + Data API. The publishable/anon key is sent to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key

# Deploy only (read by docker-compose.yml). Not needed for local `npm run dev`.
DOMAIN=notarik.nashir.tech

OPENROUTER_API_KEY=your_openrouter_api_key
# Must support image input (vision). Text-only models will fail on receipt scans.
OPENROUTER_MODEL=google/gemini-2.5-flash

DATABASE_URL=postgresql://notarik:notarik@localhost:5432/notarik

AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
AUTH_SECRET=change-me-to-a-long-random-string

# Deploy only (read by docker-compose.yml). Not needed for local `npm run dev`.
DOMAIN=notarik.nashir.tech
POSTGRES_PASSWORD=notarik
